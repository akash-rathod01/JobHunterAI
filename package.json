{
  "name": "j-jobhunter-ai",
  "private": true,
  "workspaces": [
    "agent-swarm",
    "docs-site",
    "extractors/*",
    "shared"
  ],
  "scripts": {
    "dev:all": "npm --workspace agent-swarm run dev",
    "test:all": "npm --workspace agent-swarm run test:run",
    "check:types:shared": "npm --workspace shared run check:types",
    "check:types": "npm --workspace shared run check:types && npm --workspace agent-swarm run check:types",
    "check:types:ukvisajobs": "npm --workspace ukvisajobs-extractor run check:types",
    "check:all": "./agent-swarm/node_modules/.bin/biome ci .",
    "format:all": "./agent-swarm/node_modules/.bin/biome format . --write",
    "check:types:gradcracker": "npm --workspace gradcracker-extractor run check:types",
    "docs:dev": "npm --workspace docs-site run start",
    "docs:build": "npm --workspace docs-site run build",
    "check:docs": "npm --workspace docs-site run build",
    "docs:serve": "npm --workspace docs-site run serve",
    "docs:version": "npm --workspace docs-site run docs:version",
    "release:set-version": "node ./scripts/set-agent-swarm-version.mjs",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "knip": "^5.83.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "volta": {
    "node": "22.22.1"
  }
}
